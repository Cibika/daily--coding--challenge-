Question No.: 619
Title: Biggest Single Number
Difficulty: Easy
Topic: SQL

SELECT MAX(num) AS num
FROM (
    SELECT num
    FROM MyNumbers
    GROUP BY num
    HAVING COUNT(*) = 1
) AS single_numbers;

