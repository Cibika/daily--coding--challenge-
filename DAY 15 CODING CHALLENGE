Q.NO : 125
Q.NAME : VALID PALINDROME
DIFFICULTY LEVEL-EASY



class Solution {
    public boolean isPalindrome(String s) {
        int left = 0, right = s.length() - 1;

        while (left < right) {
            // Skip non-alphanumeric characters from the left
            while (left < right && !Character.isLetterOrDigit(s.charAt(left))) {
                left++;
            }
            // Skip non-alphanumeric characters from the right
            while (left < right && !Character.isLetterOrDigit(s.charAt(right))) {
                right--;
            }

            // Compare characters (case-insensitive)
            if (Character.toLowerCase(s.charAt(left)) != Character.toLowerCase(s.charAt(right))) {
                return false;
            }

            left++;
            right--;
        }




        return true;
    }
}


Q.NO : 405
Q.NAME : CONVERT NUMBER TO HEXADECIMAL  
DIFFICULTY LEVEL- EASY


class Solution {
    public String toHex(int num) {
        if (num == 0) return "0";

        char[] hexDigits = "0123456789abcdef".toCharArray();
        StringBuilder sb = new StringBuilder();

        // Treat num as unsigned by using a long to avoid sign issues
        long n = num & 0xFFFFFFFFL;

        while (n > 0) {
            int digit = (int) (n & 0xF);   // get last 4 bits
            sb.append(hexDigits[digit]);
            n >>>= 4;                      // unsigned right shift
        }

        return sb.reverse().toString();
    }
}
